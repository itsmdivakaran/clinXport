Package: clinXport
Type: Package
Title: Clinical Data I/O for SAS XPT, SAS7BDAT, Excel, and CSV Formats
Version: 0.1.0
Authors@R: c(
    person("Mahesh", "Divakaran",
           email = "imaheshdivakaran@gmail.com",
