+                  check.names = FALSE)
> sanitize_col_names(df, version = 5)
sanitize_col_names: 2 column(s) renamed:
  'subject id' -> 'SUBJECT_'
  'visit.date' -> 'VISIT_DA'
  SUBJECT_   VISIT_DA
1        1 2024-01-01
